<ROSETTASCRIPTS>

    <SCOREFXNS>
        <ScoreFunction name="beta_nov16" weights="beta_nov16"/>
    </SCOREFXNS>

    <TASKOPERATIONS>
        <InitializeFromCommandline name="init"/>
        <IncludeCurrent name="include_current"/>
        <RestrictToRepacking name="repack_only"/>
    </TASKOPERATIONS>

    <MOVERS>

        <FastRelax
            name="relax"
            scorefxn="beta_nov16"
            repeats="5"
            cartesian="false"
            task_operations="init,include_current,repack_only"
        />

        <InterfaceAnalyzerMover
            name="interface_analysis"
            scorefxn="beta_nov16"
            interface="A_B"
            pack_input="true"
            pack_separated="true"
            packstat="true"
            interface_sc="true"
            tracer="false"
            use_jobname="true"
        />

    </MOVERS>

    <PROTOCOLS>
        <Add mover="relax"/>
        <Add mover="interface_analysis"/>
    </PROTOCOLS>

    <OUTPUT scorefxn="beta_nov16"/>

</ROSETTASCRIPTS>
